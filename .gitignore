# Godot 4+ specific ignores
.godot/
.godot_user/
.godot-user/
/android/

# Build output
build/
*.exe
export_credentials.cfg
/releases/v0.4/
/releases/v0.5/
/releases/v0.6/
/releases/v0.7/
/deliverables/
.godot_user_v05/
assets/pets/cat/orange_v2/_incoming/
assets/pets/cat/orange_v2/_review/
native/windows/godot-cpp/
native/windows/bin/win64/*.dll
native/windows/bin/win64/*.lib
native/windows/bin/win64/*.exp
native/windows/.sconsign.dblite
native/windows/*.obj
native/windows/**/*.o
native/windows/**/*.os
native/windows/**/*.obj
.tmp_appdata/
.tmp_release/
/_lmm_verify/
/tmp/
/.cache/
/.tmp_ci/
/native/windows/bin/**/*.a

# Local acceptance evidence and extracted candidates
/.manual-test/
/.tmp_acceptance/
/.tmp_public_audit/
/.tmp_installer/
/.tmp_update/

# Local runtime data and diagnostics
config.json
config.json.tmp
config.json.previous
config.invalid.*.json
debug.log
debug.log.*

# Local environment and signing material
.env
.env.*
!.env.example
*.pfx
*.p12
*.pem
*.key
*.snk
*.secrets.json

# Installer/update intermediate output
/installer/output/
/installer/cache/
/update-cache/

# Test files (temporary, should not be committed)
test_*.tscn
test_*.gd
test_*.gd.uid

# Archived experiments should not add Godot import metadata noise
experiments/**/*.import
temp/**/*.import

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Apple development output and private signing configuration
apple/**/.build/
apple/**/DerivedData/
apple/**/xcuserdata/
apple/**/*.xcuserstate
apple/Config/*.local.xcconfig
*.mobileprovision
*.provisionprofile
*.cer
*.ipa
*.xcarchive
